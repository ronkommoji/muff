# Server
PORT=3000

# Sendblue — https://sendblue.co/dashboard
SENDBLUE_API_KEY=sb_key_...
SENDBLUE_API_SECRET=sb_secret_...
MY_SENDBLUE_NUMBER=+1XXXXXXXXXX
USER_PHONE_NUMBER=+1XXXXXXXXXX

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Composio — https://app.composio.dev/
COMPOSIO_API_KEY=...
COMPOSIO_USER_ID=personal

# Supermemory — https://supermemory.ai/
SUPERMEMORY_API_KEY=sm_...

# SQLite database path
DB_PATH=./data/agent.db

# Optional: password-protect the dashboard (leave empty to disable)
DASHBOARD_PASSWORD=
